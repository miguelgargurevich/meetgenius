// ───────────────────────────────────────────────────────────────
// MeetGenius — Prisma Schema
// Diseñado para evolucionar a SaaS multiempresa.
// Preparado para RAG: ver modelo `Embedding` (migrable a pgvector).
// ───────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Identidad / Multi-tenant ───────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  meetings  Meeting[]
  auditLogs AuditLog[]
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  role           UserRole     @default(MEMBER)
  avatarUrl      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  meetings  Meeting[]   @relation("MeetingOwner")
  tasks     Task[]      @relation("TaskAssignee")
  auditLogs AuditLog[]

  @@index([organizationId])
}

// ── Reuniones ──────────────────────────────────────────────────

enum MeetingStatus {
  DRAFT // creada, sin grabar
  RECORDING // grabando
  PAUSED // grabación pausada
  PROCESSING // transcribiendo / analizando
  COMPLETED // análisis listo
  FAILED // error en pipeline
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model Meeting {
  id             String        @id @default(cuid())
  title          String
  description    String?
  status         MeetingStatus @default(DRAFT)
  scheduledAt    DateTime?
  startedAt      DateTime?
  endedAt        DateTime?
  durationSec    Int           @default(0)
  participants   String[]      @default([])
  sentiment      Sentiment?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  owner          User?        @relation("MeetingOwner", fields: [ownerId], references: [id])
  ownerId        String?

  recording     Recording?
  transcription Transcription?
  summary       Summary?
  tasks         Task[]
  agreements    Agreement[]
  risks         Risk[]
  openQuestions OpenQuestion[]
  nextSteps     NextStep[]
  reports       Report[]
  aiJobs        AIJob[]
  embeddings    Embedding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([createdAt])
}

model Recording {
  id          String   @id @default(cuid())
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId   String   @unique
  filePath    String
  mimeType    String   @default("audio/webm")
  sizeBytes   Int      @default(0)
  durationSec Int      @default(0)
  createdAt   DateTime @default(now())
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

model Transcription {
  id          String    @id @default(cuid())
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId   String    @unique
  text        String    @db.Text
  language    String    @default("es")
  provider    String    @default("openai-whisper")
  status      JobStatus @default(PENDING)
  error       String?
  runtimeMs   Int       @default(0)
  segments    Json? // [{ start, end, speaker?, text }]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Análisis IA ────────────────────────────────────────────────

model Summary {
  id        String   @id @default(cuid())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String   @unique
  bullets   String[] @default([]) // máximo 10 puntos ejecutivos
  createdAt DateTime @default(now())
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

model Task {
  id          String     @id @default(cuid())
  meeting     Meeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId   String
  title       String
  description String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId  String?
  assigneeRaw String? // nombre textual extraído por IA si no mapea a un User
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([meetingId])
  @@index([status])
}

enum AgreementStatus {
  PROPOSED
  CONFIRMED
  AT_RISK
  DONE
}

model Agreement {
  id          String          @id @default(cuid())
  meeting     Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId   String
  title       String
  description String?
  owner       String? // responsable textual
  targetDate  DateTime?
  status      AgreementStatus @default(PROPOSED)
  createdAt   DateTime        @default(now())

  @@index([meetingId])
}

enum RiskImpact {
  LOW
  MEDIUM
  HIGH
}

enum RiskStatus {
  OPEN
  MITIGATED
  CLOSED
}

model Risk {
  id         String     @id @default(cuid())
  meeting    Meeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId  String
  risk       String
  impact     RiskImpact @default(MEDIUM)
  mitigation String?
  status     RiskStatus @default(OPEN)
  createdAt  DateTime   @default(now())

  @@index([meetingId])
}

model OpenQuestion {
  id        String   @id @default(cuid())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  question  String
  createdAt DateTime @default(now())

  @@index([meetingId])
}

model NextStep {
  id        String   @id @default(cuid())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  step      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([meetingId])
}

// ── Reportes ───────────────────────────────────────────────────

enum ReportFormat {
  PDF
  EXCEL
}

model Report {
  id        String       @id @default(cuid())
  meeting   Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  format    ReportFormat
  filePath  String
  createdAt DateTime     @default(now())

  @@index([meetingId])
}

// ── Infra IA: jobs y embeddings (RAG-ready) ────────────────────

enum AIJobType {
  TRANSCRIPTION
  ANALYSIS
  EMBEDDING
  CHAT
}

model AIJob {
  id         String    @id @default(cuid())
  meeting    Meeting?  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId  String?
  type       AIJobType
  provider   String
  model      String?
  status     JobStatus @default(PENDING)
  inputMeta  Json?
  outputMeta Json?
  error      String?
  runtimeMs  Int       @default(0)
  tokensIn   Int       @default(0)
  tokensOut  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([type, status])
}

// Embeddings para RAG. Hoy guardamos el vector como Json (Float[] serializado).
// Migración futura a pgvector: cambiar `vector Json?` por
//   vector Unsupported("vector(1536)")?  + extensión pgvector.
model Embedding {
  id        String   @id @default(cuid())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  chunk     String   @db.Text
  vector    Json?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([meetingId])
}

// ── Auditoría ──────────────────────────────────────────────────

model AuditLog {
  id             String        @id @default(cuid())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?
  user           User?         @relation(fields: [userId], references: [id])
  userId         String?
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
}
