// ───────────────────────────────────────────────────────────────
// MeetGenius — Prisma Schema (SQLite embebido)
// La base de datos viaja dentro de la app de escritorio (un archivo),
// sin servidor ni Docker. Preparado para RAG: ver modelo `Embedding`.
//
// Nota: SQLite no soporta enums nativos ni listas escalares (String[]).
// Los "enums" se modelan como String (los valores válidos se documentan
// junto a cada campo) y las listas como Json.
// ───────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  // Motores para empaquetar la app en Apple Silicon e Intel.
  binaryTargets = ["native", "darwin", "darwin-arm64"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Identidad / Multi-tenant ───────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  meetings  Meeting[]
  auditLogs AuditLog[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  role           String       @default("MEMBER") // OWNER | ADMIN | MEMBER
  avatarUrl      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  meetings  Meeting[]  @relation("MeetingOwner")
  tasks     Task[]     @relation("TaskAssignee")
  auditLogs AuditLog[]

  @@index([organizationId])
}

// ── Reuniones ──────────────────────────────────────────────────

model Meeting {
  id          String  @id @default(cuid())
  title       String
  description String?
  // DRAFT | RECORDING | PAUSED | PROCESSING | COMPLETED | FAILED
  status      String  @default("DRAFT")
  scheduledAt DateTime?
  scheduledMinutes Int? // duración prevista (para pintar el bloque en el calendario)
  startedAt   DateTime?
  endedAt     DateTime?
  durationSec Int       @default(0)
  meetingUrl  String? // enlace de la videollamada (Meet/Teams/Zoom)
  externalEventId String? // id del evento en el calendario de macOS (dedup)
  participants Json     @default("[]") // string[] serializado
  sentiment   String? // POSITIVE | NEUTRAL | NEGATIVE

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  owner          User?        @relation("MeetingOwner", fields: [ownerId], references: [id])
  ownerId        String?

  recording     Recording?
  transcription Transcription?
  summary       Summary?
  tasks         Task[]
  agreements    Agreement[]
  risks         Risk[]
  openQuestions OpenQuestion[]
  nextSteps     NextStep[]
  reports       Report[]
  aiJobs        AIJob[]
  embeddings    Embedding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([createdAt])
}

model Recording {
  id          String   @id @default(cuid())
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId   String   @unique
  filePath    String
  mimeType    String   @default("audio/webm")
  sizeBytes   Int      @default(0)
  durationSec Int      @default(0)
  createdAt   DateTime @default(now())
}

model Transcription {
  id        String   @id @default(cuid())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String   @unique
  text      String
  language  String   @default("es")
  provider  String   @default("groq-whisper")
  status    String   @default("PENDING") // PENDING | RUNNING | SUCCEEDED | FAILED
  error     String?
  runtimeMs Int      @default(0)
  segments  Json? // [{ start, end, speaker?, text }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Análisis IA ────────────────────────────────────────────────

model Summary {
  id        String   @id @default(cuid())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String   @unique
  bullets   Json     @default("[]") // string[] serializado (máx 10)
  createdAt DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId   String
  title       String
  description String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId  String?
  assigneeRaw String?
  priority    String    @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  status      String    @default("TODO") // TODO | IN_PROGRESS | DONE | BLOCKED
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([meetingId])
  @@index([status])
}

model Agreement {
  id          String    @id @default(cuid())
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId   String
  title       String
  description String?
  owner       String?
  targetDate  DateTime?
  status      String    @default("PROPOSED") // PROPOSED | CONFIRMED | AT_RISK | DONE
  createdAt   DateTime  @default(now())

  @@index([meetingId])
}

model Risk {
  id         String   @id @default(cuid())
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId  String
  risk       String
  impact     String   @default("MEDIUM") // LOW | MEDIUM | HIGH
  mitigation String?
  status     String   @default("OPEN") // OPEN | MITIGATED | CLOSED
  createdAt  DateTime @default(now())

  @@index([meetingId])
}

model OpenQuestion {
  id        String   @id @default(cuid())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  question  String
  createdAt DateTime @default(now())

  @@index([meetingId])
}

model NextStep {
  id        String   @id @default(cuid())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  step      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([meetingId])
}

// ── Reportes ───────────────────────────────────────────────────

model Report {
  id        String   @id @default(cuid())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  format    String // PDF | EXCEL
  filePath  String
  createdAt DateTime @default(now())

  @@index([meetingId])
}

// ── Infra IA: jobs y embeddings (RAG-ready) ────────────────────

model AIJob {
  id         String   @id @default(cuid())
  meeting    Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId  String?
  type       String // TRANSCRIPTION | ANALYSIS | EMBEDDING | CHAT
  provider   String
  model      String?
  status     String   @default("PENDING") // PENDING | RUNNING | SUCCEEDED | FAILED
  inputMeta  Json?
  outputMeta Json?
  error      String?
  runtimeMs  Int      @default(0)
  tokensIn   Int      @default(0)
  tokensOut  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type, status])
}

// Embeddings para RAG. El vector se guarda como Json (Float[] serializado).
model Embedding {
  id        String   @id @default(cuid())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  chunk     String
  vector    Json?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([meetingId])
}

// ── Auditoría ──────────────────────────────────────────────────

model AuditLog {
  id             String        @id @default(cuid())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?
  user           User?         @relation(fields: [userId], references: [id])
  userId         String?
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
}
