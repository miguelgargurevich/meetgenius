# ───────────────────────────────────────────────────────────────
# MeetGenius — Variables de entorno
# Copia este archivo a `.env` y completa los valores.
# ───────────────────────────────────────────────────────────────

# Base de datos: SQLite embebido (sin servidor ni Docker)
DATABASE_URL="file:./dev.db"

# ── IA: Análisis ───────────────────────────────────────────────
# Proveedor activo: groq | gemini | grok | openai | mock
AI_PROVIDER="groq"

# Groq Cloud (OpenAI-compatible) — análisis + transcripción Whisper
GROQ_API_KEY=""
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_MODEL="llama-3.3-70b-versatile"

# Google Gemini (vía endpoint compatible con OpenAI)
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
GEMINI_MODEL="gemini-2.0-flash"

# xAI Grok (opcional)
XAI_API_KEY=""
XAI_BASE_URL="https://api.x.ai/v1"
XAI_MODEL="grok-2-latest"

# OpenAI (opcional)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ── IA: Transcripción ──────────────────────────────────────────
# groq-whisper | openai-whisper | mock
TRANSCRIPTION_PROVIDER="groq-whisper"
WHISPER_MODEL="whisper-large-v3"

# Almacenamiento de grabaciones (ruta local en dev)
STORAGE_DIR="./.storage/recordings"

# App
NEXT_PUBLIC_APP_NAME="MeetGenius"
NODE_ENV="development"
